# === KIS OpenAPI (한국투자증권) ===
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_ACCOUNT_NUMBER=your_account_number_here
KIS_ACCOUNT_PRODUCT_CODE=01
# sandbox: openapivts.koreainvestment.com:9443 | live: openapi.koreainvestment.com:9443
KIS_BASE_URL=https://openapivts.koreainvestment.com:9443

# === AI API Keys (CLI fallback용) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# === Trading Mode ===
# paper: 모의거래 (기본값, 안전) | live: 실거래
TRADING_MODE=paper

# === AI Agent Settings ===
MAX_ROUNDS=5
CONVERGENCE_CONF=0.65
MIN_CONFIDENCE=0.40
TIMEOUT_PER_ROUND=120
OSCILLATION_WINDOW=3

# === Risk Management ===
MAX_POSITION_PCT=0.20
STOP_LOSS_PCT=0.05
DAILY_LOSS_LIMIT_PCT=0.03
MAX_OPEN_POSITIONS=5
MIN_TRADE_CONFIDENCE=0.65

# === Database ===
DB_PATH=data_store/trading.db

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=data_store/logs/trading.log
